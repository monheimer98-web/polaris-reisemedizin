---
/**
 * „Steckbrief"-Kernfaktenbox für Krankheitsbild-Seiten: rendert die fünf
 * Kompaktfakten (Erreger, Übertragung, Verbreitung, Reiseimpfung, Hinweis)
 * aus `diseaseFacts` als scannbare, markenkonforme Schnellübersicht oben auf
 * der Seite. Labels stammen aus dem i18n-Wörterbuch, Werte sind lokalisiert.
 * Wird von `ContentLayout` automatisch je Slug eingebunden – die einzelnen
 * Seiten müssen nicht angepasst werden.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { DiseaseFacts } from '../data/diseaseFacts';
import type { UiKey } from '../i18n/ui';

interface Props {
  facts: DiseaseFacts;
}

const { facts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Vier Kernfakten als Definitionsliste; jeder Eintrag mit dezentem Linien-Icon.
const rows: { key: UiKey; value: string; icon: string }[] = [
  {
    key: 'facts.pathogen',
    value: facts.pathogen[lang],
    // Erreger – Keim/„Sonne" als abstraktes Erreger-Symbol
    icon: '<circle cx="12" cy="12" r="4.5"/><path d="M12 3v2.2M12 18.8V21M3 12h2.2M18.8 12H21M5.6 5.6l1.6 1.6M16.8 16.8l1.6 1.6M18.4 5.6l-1.6 1.6M7.2 16.8l-1.6 1.6"/>',
  },
  {
    key: 'facts.transmission',
    value: facts.transmission[lang],
    // Übertragung – radial sich ausbreitende Bögen
    icon: '<path d="M5 12a7 7 0 0 1 14 0M8.2 12a3.8 3.8 0 0 1 7.6 0"/><circle cx="12" cy="12" r="1.1"/>',
  },
  {
    key: 'facts.regions',
    value: facts.regions[lang],
    // Verbreitung – Globus
    icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18 15 15 0 0 1 0-18"/>',
  },
  {
    key: 'facts.vaccine',
    value: facts.vaccine[lang],
    // Reiseimpfung – Schutzschild mit Häkchen
    icon: '<path d="M12 3l7 3v5c0 4-3 7-7 9-4-2-7-5-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  },
];
---

<section
  aria-label={t('facts.title')}
  class="mb-12 overflow-hidden rounded-2xl border border-line bg-gradient-to-br from-petrol-50/70 via-white to-white shadow-[0_1px_0_rgba(14,59,67,0.04)]"
>
  <p class="flex items-center gap-2.5 border-b border-line/80 bg-white/50 px-5 py-3.5 sm:px-6">
    <span class="rule-gold"></span>
    <span class="text-xs font-semibold uppercase tracking-[0.14em] text-petrol-900">{t('facts.title')}</span>
  </p>

  <dl class="grid gap-x-6 gap-y-5 px-5 py-5 sm:grid-cols-2 sm:px-6 sm:py-6">
    {
      rows.map((row) => (
        <div class="flex items-start gap-3">
          <span
            class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-xl border border-petrol-100 bg-white text-petrol-700"
            aria-hidden="true"
          >
            <svg
              class="h-[18px] w-[18px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={row.icon}
            />
          </span>
          <div class="min-w-0">
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-soft">{t(row.key)}</dt>
            <dd class="mt-0.5 text-[0.95rem] font-medium leading-snug text-ink">{row.value}</dd>
          </div>
        </div>
      ))
    }
  </dl>

  <p class="flex items-start gap-3 border-t border-line/80 bg-gold-50/40 px-5 py-4 sm:px-6">
    <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-xl border border-gold-200 bg-white text-gold-600" aria-hidden="true">
      <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 11v5M12 7.5h.01" />
      </svg>
    </span>
    <span class="min-w-0">
      <span class="block text-xs font-semibold uppercase tracking-wider text-gold-700">{t('facts.note')}</span>
      <span class="mt-0.5 block text-[0.95rem] leading-snug text-ink">{facts.note[lang]}</span>
    </span>
  </p>
</section>
