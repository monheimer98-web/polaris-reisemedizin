---
/**
 * Inhalt der Seite „Kosten & Abrechnung". Selbsttragend: leitet die Sprache
 * aus der URL ab und rendert die transparente Preisorientierung aus
 * `kostenPage`. Beträge sind Richtwerte nach GOÄ (siehe Daten-Modul).
 */
import { getLangFromUrl, formatReviewDate } from '../i18n/utils';
import { kostenPage as page } from '../data/kosten';

const lang = getLangFromUrl(Astro.url);
const reviewedLabel = lang === 'de' ? 'Stand' : 'Last reviewed';
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
      </div>
    </div>
  </header>

  {/* Einleitung */}
  <section class="u-container pt-14 sm:pt-16">
    <div class="max-w-3xl space-y-4 leading-relaxed text-ink-soft">
      {page.intro[lang].map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  {/* Preisgruppen */}
  <section class="u-container pt-10 sm:pt-12">
    <div class="grid gap-6 lg:grid-cols-2">
      {
        page.groups.map((group) => (
          <div class="card flex flex-col">
            <h2 class="font-display text-xl text-petrol-900">{group.heading[lang]}</h2>
            {group.note && <p class="mt-2 text-sm leading-relaxed text-ink-soft">{group.note[lang]}</p>}

            <div
              class="mt-4 flex items-center justify-between border-b border-line pb-2 text-xs font-semibold uppercase tracking-[0.14em] text-petrol-700/70"
              aria-hidden="true"
            >
              <span>{page.tableHead.service[lang]}</span>
              <span>{page.tableHead.price[lang]}</span>
            </div>

            <dl class="mt-1">
              {group.items.map((item) => (
                <div class="flex flex-col gap-1 border-b border-line py-4 last:border-0 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                  <div class="min-w-0">
                    <dt class="font-medium text-petrol-900">{item.service[lang]}</dt>
                    <dd class="mt-1 text-sm leading-relaxed text-ink-soft">{item.detail[lang]}</dd>
                  </div>
                  <p class="shrink-0 whitespace-nowrap font-display text-lg text-gold-700 sm:text-right">
                    {item.price[lang]}
                  </p>
                </div>
              ))}
            </dl>
          </div>
        ))
      }
    </div>
  </section>

  {/* Hinweise */}
  <section class="u-container pt-12 sm:pt-14">
    <div class="grid gap-6 sm:grid-cols-2">
      {
        page.notes.map((note) => (
          <div class="rounded-2xl border border-line bg-white/60 p-6 shadow-[var(--shadow-soft)] sm:p-7">
            <h2 class="font-display text-lg text-petrol-900">{note.heading[lang]}</h2>
            <div class="mt-3 space-y-3 text-sm leading-relaxed text-ink-soft">
              {note.body[lang].map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-3xl text-xs leading-relaxed text-ink-soft/80">{page.disclaimer[lang]}</p>
    <p class="mt-2 text-xs text-ink-soft/70">{reviewedLabel}: {formatReviewDate(page.lastReviewed, lang)}</p>
  </section>
</article>
