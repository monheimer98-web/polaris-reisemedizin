---
/**
 * Übersichts-Karte für die Eltern-Seiten /leistungen und /krankheitsbilder.
 * Icon, Titel, Kurzbeschreibung und Link-Affordanz; die gesamte Karte ist ein
 * Link. Alle Texte werden bereits übersetzt als Props übergeben.
 */
interface Props {
  /** Kartentitel (bereits übersetzt). */
  title: string;
  /** Kurzbeschreibung (bereits übersetzt). */
  text: string;
  /** Ziel-URL (bereits lokalisiert). */
  href: string;
  /** Link-Text / Handlungsaufforderung (bereits übersetzt). */
  cta: string;
  /** Icon-Variante (Schlüssel von `icons`). */
  variant?: string;
}

const { title, text, href, cta, variant = 'yellowFever' } = Astro.props;

