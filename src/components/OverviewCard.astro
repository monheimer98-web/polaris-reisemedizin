---
/**
 * Übersichts-Karte für die Eltern-Seiten /leistungen und /krankheitsbilder.
 * Icon, Titel, Kurzbeschreibung und Link-Affordanz; die gesamte Karte ist ein
 * Link. Alle Texte werden bereits übersetzt als Props übergeben.
 */
interface Props {
  /** Kartentitel (bereits übersetzt). */
  title: string;
  /** Kurzbeschreibung (bereits übersetzt). */
  text: string;
  /** Ziel-URL (bereits lokalisiert). */
  href: string;
  /** Link-Text / Handlungsaufforderung (bereits übersetzt). */
  cta: string;
  /** Icon-Variante (Schlüssel von `icons`). */
  variant?: string;
}

const { title, text, href, cta, variant = 'yellowFever' } = Astro.props;

/** Statische, vertrauenswürdige Inline-SVG-Piktogramme (Strich, 24×24). */
const icons: Record<string, string> = {
  yellowFever:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18" stroke-linecap="round"/><path d="M12 3c2.6 2.5 2.6 15.5 0 18M12 3c-2.6 2.5-2.6 15.5 0 18" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  fsme:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 20c0-8 6-14 16-14 0 10-6 16-14 16-1.2 0-2-.8-2-2Z" stroke-linejoin="round"/><path d="M8.5 15.5C11 12 14 9.8 18 8.4" stroke-linecap="round"/></svg>',
  consultation:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 4v-.8A1.2 1.2 0 0 1 10.2 2h3.6A1.2 1.2 0 0 1 15 3.2V4" stroke-linejoin="round"/><path d="M8.5 10h7M8.5 14h7M8.5 18h4" stroke-linecap="round"/></svg>',
  travelVaccinations:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3l7 2.5v5c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9v-5L12 3Z" stroke-linejoin="round"/><path d="M12 9.5v5M9.5 12h5" stroke-linecap="round"/></svg>',
  malaria:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><ellipse cx="12" cy="13" rx="2.6" ry="5"/><circle cx="12" cy="5.5" r="1.8"/><path d="M9.4 10 4.5 7M14.6 10l4.9-3M9.4 13H4M14.6 13H20M9.4 16l-4.5 3M14.6 16l4.5 3" stroke-linecap="round"/></svg>',
  altitude:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 19l6-9 3.5 5 2-3L21 19H3Z" stroke-linejoin="round"/><path d="m7.4 13.5 1.6-2.4 2 2.9" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  costs:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M14.5 8.5a3 3 0 0 0-2.5-1.2c-1.7 0-2.7 1-2.7 2.1 0 2.8 5.4 1.6 5.4 4.4 0 1.2-1.1 2.2-2.7 2.2a3 3 0 0 1-2.6-1.3M12 6v1.3M12 16.7V18" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  business:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 20h18M4 20V9l5.5-3v14M14 20V4l6 3v13" stroke-linejoin="round"/><path d="M7 11h.01M7 14h.01M17 10h.01M17 13h.01M17 16h.01" stroke-linecap="round"/></svg>',
};
---

<a
  href={href}
  class="card group flex flex-col transition-colors hover:border-petrol-200 focus-visible:border-petrol-300"
>
  <span
    class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-petrol-800/[0.06] text-petrol-700"
    set:html={icons[variant] ?? icons.yellowFever}
  />

  <h2 class="mt-5 font-display text-xl text-petrol-900">{title}</h2>
  <p class="mt-3 text-ink-soft">{text}</p>

  <span class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-petrol-700 transition-colors group-hover:text-petrol-900">
    {cta}
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M3 8h9M9 5l3 3-3 3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
