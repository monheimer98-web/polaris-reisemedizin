---
/**
 * Wiederverwendbare Leistungs-Karte: Icon, Titel, Kurzbeschreibung,
 * belegbare Fakten-Liste und Detail-Link. Genutzt im Leistungs-Überblick
 * (Gelbfieber, FSME). Sprache aus der URL für den CTA-Text.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  /** Kartentitel (bereits übersetzt). */
  title: string;
  /** Kurzbeschreibung (bereits übersetzt). */
  text: string;
  /** Belegbare Kernfakten (bereits übersetzt). */
  facts: string[];
  /** Ziel-URL der Detailseite (bereits lokalisiert). */
  href: string;
  /** Icon-Variante. */
  variant?: 'yellowFever' | 'fsme' | 'consultation' | 'travelVaccinations';
}

const { title, text, facts, href, variant = 'yellowFever' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article class="card group flex flex-col transition-colors hover:border-petrol-200">
  <div class="flex items-center gap-3">
    <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-petrol-50 to-petrol-100 text-petrol-700 ring-1 ring-inset ring-petrol-100 transition-colors group-hover:from-petrol-100 group-hover:to-petrol-200/70">
      {variant === 'yellowFever' && (
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <path d="M3 12h18" stroke-linecap="round" />
          <path d="M12 3c2.6 2.5 2.6 15.5 0 18M12 3c-2.6 2.5-2.6 15.5 0 18" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      )}
      {variant === 'fsme' && (
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4 20c0-8 6-14 16-14 0 10-6 16-14 16-1.2 0-2-.8-2-2Z" stroke-linejoin="round" />
          <path d="M8.5 15.5C11 12 14 9.8 18 8.4" stroke-linecap="round" />
        </svg>
      )}
      {variant === 'consultation' && (
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="5" y="4" width="14" height="17" rx="2" />
          <path d="M9 4v-.8A1.2 1.2 0 0 1 10.2 2h3.6A1.2 1.2 0 0 1 15 3.2V4" stroke-linejoin="round" />
          <path d="M8.5 10h7M8.5 14h7M8.5 18h4" stroke-linecap="round" />
        </svg>
      )}
      {variant === 'travelVaccinations' && (
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 3l7 2.5v5c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9v-5L12 3Z" stroke-linejoin="round" />
          <path d="M12 9.5v5M9.5 12h5" stroke-linecap="round" />
        </svg>
      )}
    </span>
    <h3 class="font-display text-xl text-petrol-900">{title}</h3>
  </div>

  <p class="mt-4 text-ink-soft">{text}</p>

  <ul class="mt-5 space-y-2.5">
    {
      facts.map((fact) => (
        <li class="flex items-start gap-2.5 text-sm text-petrol-900/85">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-500" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="10" cy="10" r="7.5" opacity="0.25" />
            <path d="M6.4 10.2l2.2 2.2 4.9-5.1" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{fact}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-auto pt-6">
    <a href={href} class="inline-flex items-center gap-1.5 text-sm font-semibold text-petrol-700 transition-colors hover:text-petrol-900">
      {t('cta.serviceDetail')}
      <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M3 8h9M9 5l3 3-3 3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</article>
