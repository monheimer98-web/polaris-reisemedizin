---
/**
 * Reiseregion-Karte für die Reiseziele-Übersicht. Zeigt Icon, Regionenname,
 * Kurzbeschreibung, Beispielländer und die wichtigsten Impfthemen als Chips.
 * Die gesamte Karte ist ein Link auf die Regionen-Detailseite.
 */
import type { Locale } from '../config/site';
import type { DestinationRegion } from '../data/reiseziele/regions';

interface Props {
  region: DestinationRegion;
  lang: Locale;
  href: string;
  /** Bereits übersetzte Labels (Beispielländer / Themen / CTA). */
  labels: { examples: string; topics: string; cta: string };
}

const { region, lang, href, labels } = Astro.props;

/** Dezente Inline-SVG-Motive je Region (Strich, 24×24). */
const icons: Record<string, string> = {
  afrika:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="18" cy="6.5" r="2.2"/><path d="M3 20h18M10 20v-8" stroke-linecap="round"/><path d="M5 12.5c1.4-1.4 3.2-2 5-2s3.6.6 5 2" stroke-linecap="round"/></svg>',
  asien:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3 5 7h14L12 3Z" stroke-linejoin="round"/><path d="M6.5 7 4 11h16l-2.5-4M7.5 11 6 15h12l-1.5-4" stroke-linejoin="round"/><path d="M9 15v5h6v-5M4 20h16" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  lateinamerika:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 20h18" stroke-linecap="round"/><path d="M5 16v-3h3v-3h2V7h4v3h2v3h3v3" stroke-linejoin="round"/></svg>',
  naherOsten:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 20h16" stroke-linecap="round"/><path d="M7 20v-6M17 20v-6" stroke-linecap="round"/><path d="M7 14a5 5 0 0 1 10 0" stroke-linejoin="round"/><path d="M12 9V6" stroke-linecap="round"/><circle cx="12" cy="4.5" r="1"/></svg>',
  europa:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 20h18" stroke-linecap="round"/><path d="M4 20V9h16v11" stroke-linejoin="round"/><path d="M4 9 12 5l8 4" stroke-linejoin="round"/><path d="M7 20v-4a2 2 0 0 1 4 0v4M13 20v-4a2 2 0 0 1 4 0v4" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  ozeanien:
    '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 18q2-2 4 0t4 0 4 0 4 0" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 18V9" stroke-linecap="round"/><path d="M13 9c-2-1.5-4-1.3-5.5 0M13 9c2-1.5 4-1.3 5.5 0M13 9c-1-2-3-2.8-4.5-2.5M13 9c1-2 3-2.8 4.5-2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---

<a
  href={href}
  class="card group flex flex-col transition duration-200 hover:-translate-y-1 hover:border-petrol-200 hover:shadow-[var(--shadow-card-hover)] focus-visible:border-petrol-300"
>
  <span
    class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-petrol-50 to-petrol-100 text-petrol-700 ring-1 ring-inset ring-petrol-100 transition-colors group-hover:from-petrol-100 group-hover:to-petrol-200/70"
    set:html={icons[region.icon] ?? icons.afrika}
  />

  <h3 class="mt-5 font-display text-xl text-petrol-900">{region.name[lang]}</h3>
  <p class="mt-3 text-ink-soft">{region.summary[lang]}</p>

  <p class="mt-4 text-sm text-ink-soft">
    <span class="font-semibold text-petrol-800">{labels.examples}:</span>
    {' '}{region.examples[lang]}
  </p>

  <div class="mt-4">
    <span class="sr-only">{labels.topics}</span>
    <ul class="flex flex-wrap gap-1.5">
      {
        region.vaccines[lang].map((vaccine) => (
          <li class="rounded-full border border-petrol-100 bg-cream/60 px-2.5 py-1 text-xs font-medium text-petrol-800">
            {vaccine}
          </li>
        ))
      }
    </ul>
  </div>

  <span class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-petrol-700 transition-colors group-hover:text-petrol-900">
    {labels.cta}
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M3 8h9M9 5l3 3-3 3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
