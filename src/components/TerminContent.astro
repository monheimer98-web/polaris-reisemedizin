---
/**
 * Inhalt der „Termin buchen"-Seite. Selbsttragend: leitet die Sprache aus der
 * URL ab und rendert Rahmentexte aus `bookingPage`.
 *
 * HINWEIS: Die Online-Terminbuchung ist zurzeit deaktiviert (im Umbau). Statt
 * des Buchungs-Widgets zeigt die Seite einen freundlichen Umbau-Hinweis mit
 * Telefon-/E-Mail-Weg (`page.widgetNotice`). Telefon, E-Mail und Sprechzeiten
 * stammen zentral aus `site.contact` bzw. `site.openingHours`. Sobald die
 * Buchung wieder live geht, kann hier erneut ein Buchungs-Widget eingesetzt
 * werden (siehe git-Historie: BookingEmbed/BookingForm).
 */
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';
import { site } from '../config/site';
import { bookingPage as page } from '../data/termin';

const lang = getLangFromUrl(Astro.url);
const notice = page.widgetNotice;
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
      </div>
    </div>
  </header>

  {/* Einleitung + Buchungs-Widget */}
  <section class="u-container py-14 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.6fr)] lg:gap-14">
      <div class="max-w-prose space-y-4 text-lg leading-relaxed text-ink-soft">
        {page.intro[lang].map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.widgetHeading[lang]}</h2>
        <div class="mt-6">
          {/* Online-Buchung zurzeit deaktiviert (im Umbau): freundlicher Hinweis
              mit direktem Telefon-/E-Mail-Weg statt Buchungs-Widget. */}
          <div class="rounded-2xl border border-line bg-white p-7 shadow-[var(--shadow-card)] sm:p-9">
            <span class="inline-flex items-center gap-2 rounded-full bg-sand px-3 py-1 text-xs font-semibold uppercase tracking-wider text-gold-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14.7 6.3a5 5 0 0 0-6.9 6.9L3 18v3h3l4.8-4.8a5 5 0 0 0 6.9-6.9l-2.7 2.7-2.3-.6-.6-2.3z" />
              </svg>
              {notice.badge[lang]}
            </span>
            <h3 class="mt-4 font-display text-xl text-petrol-900 sm:text-2xl">{notice.title[lang]}</h3>
            <p class="mt-3 leading-relaxed text-ink-soft">{notice.body[lang]}</p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a href={site.contact.phoneHref} class="btn-gold justify-center">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                <span>{notice.phoneCtaLabel[lang]}: <span class="whitespace-nowrap">{site.contact.phone}</span></span>
              </a>
              <a href={site.contact.emailHref} class="btn-ghost justify-center">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="m3 7 9 6 9-6" />
                </svg>
                <span>{notice.emailCtaLabel[lang]}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Terminarten zur Orientierung */}
  <section class="u-container pb-4 sm:pb-6">
    <div class="max-w-2xl">
      <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.appointmentTypes.heading[lang]}</h2>
      <p class="mt-3 text-ink-soft">{page.appointmentTypes.lead[lang]}</p>
    </div>

    <ul class="mt-8 grid gap-5 sm:grid-cols-2">
      {
        page.appointmentTypes.items.map((item) => (
          <li
            class={`relative flex flex-col gap-4 rounded-2xl border p-6 sm:p-7 ${
              item.recommended
                ? 'border-gold-300 bg-white shadow-[var(--shadow-card)]'
                : item.enabled
                  ? 'border-line bg-white shadow-[var(--shadow-soft)]'
                  : 'border-line bg-sand/40'
            }`}
          >
            <div class="flex items-start justify-between gap-3">
              <span
                class={`inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${
                  item.enabled ? 'bg-petrol-800/[0.06] text-petrol-700' : 'bg-petrol-800/[0.04] text-petrol-400'
                }`}
              >
                {item.icon === 'consultation' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="8" y="2" width="8" height="4" rx="1" />
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                    <path d="M12 11h4M12 16h4M8 11h.01M8 16h.01" />
                  </svg>
                )}
                {item.icon === 'focus' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88Z" />
                  </svg>
                )}
                {item.icon === 'vaccination' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m18 2 4 4" />
                    <path d="m17 7 3-3" />
                    <path d="M19 9 8.7 19.3c-1 1-2.5 1-3.4 0l-.6-.6c-1-1-1-2.5 0-3.4L15 5" />
                    <path d="m9 11 4 4" />
                    <path d="m5 19-3 3" />
                    <path d="m14 4 6 6" />
                  </svg>
                )}
                {item.icon === 'yellowFever' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
              </span>

              {item.recommended && (
                <span class="shrink-0 rounded-full bg-gold-400 px-3 py-1 text-xs font-semibold text-petrol-900">
                  {page.appointmentTypes.recommendedLabel[lang]}
                </span>
              )}
              {!item.enabled && (
                <span class="shrink-0 rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-ink-soft">
                  {page.appointmentTypes.pendingLabel[lang]}
                </span>
              )}
            </div>

            <div class="space-y-2">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class={`text-lg font-semibold ${item.enabled ? 'text-petrol-900' : 'text-petrol-700'}`}>{item.name[lang]}</h3>
                <span class="text-xs font-medium uppercase tracking-wider text-gold-700">{item.duration[lang]}</span>
              </div>
              <p class="text-sm leading-relaxed text-ink-soft">{item.description[lang]}</p>
            </div>

            {item.price && (
              <div class="mt-auto flex items-baseline justify-between gap-3 border-t border-line/60 pt-3.5">
                <span class="text-[0.7rem] font-medium uppercase tracking-wider text-ink-soft/70">
                  {page.appointmentTypes.priceNoteLabel[lang]}
                </span>
                <span class={`text-base font-semibold ${item.enabled ? 'text-petrol-900' : 'text-petrol-700'}`}>
                  {item.price[lang]}
                </span>
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <a
      href={getLocalizedPath(page.appointmentTypes.costsPath, lang)}
      class="mt-8 inline-flex items-center gap-2 font-semibold text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
    >
      {page.appointmentTypes.costsLabel[lang]}
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </section>

  {/* Vorbereitung */}
  <section class="border-y border-line bg-sand/60">
    <div class="u-container py-14 sm:py-16">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.prepare.heading[lang]}</h2>
        <p class="mt-3 text-ink-soft">{page.prepare.lead[lang]}</p>
      </div>

      <ul class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          page.prepare.points[lang].map((point) => (
            <li class="card flex items-start gap-3">
              <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-petrol-800/[0.06] text-petrol-700">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12.5l4 4 10-10.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="leading-relaxed text-ink-soft">{point}</span>
            </li>
          ))
        }
      </ul>

      <a
        href={getLocalizedPath(page.prepare.morePath, lang)}
        class="mt-8 inline-flex items-center gap-2 font-semibold text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
      >
        {page.prepare.moreLabel[lang]}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

  {/* Kontakt-Fallback */}
  <section class="u-container py-14 sm:py-16">
    <div class="rounded-3xl border border-line bg-white/60 p-8 shadow-[var(--shadow-soft)] sm:p-10">
      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.contact.heading[lang]}</h2>
          <p class="mt-3 max-w-md leading-relaxed text-ink-soft">{page.contact.body[lang]}</p>

          <dl class="mt-6 space-y-3 text-sm">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <dt class="font-semibold uppercase tracking-wider text-gold-700">{page.contact.phoneLabel[lang]}</dt>
              <dd>
                <a
                  href={site.contact.phoneHref}
                  class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                >
                  {site.contact.phone}
                </a>
              </dd>
            </div>
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <dt class="font-semibold uppercase tracking-wider text-gold-700">{page.contact.emailLabel[lang]}</dt>
              <dd>
                <a
                  href={site.contact.emailHref}
                  class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                >
                  {site.contact.email}
                </a>
              </dd>
            </div>
          </dl>
        </div>

        <div>
          <h3 class="text-base font-semibold text-petrol-900">{page.contact.hoursLabel[lang]}</h3>
          <dl class="mt-4 divide-y divide-line/70 border-y border-line/70">
            {
              site.openingHours.map((entry) => (
                <div class="flex items-baseline justify-between gap-4 py-2.5 text-sm">
                  <dt class="font-medium text-petrol-900">{entry.day[lang]}</dt>
                  <dd class="text-right text-ink-soft">{entry.hours[lang]}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
  </section>
</article>
