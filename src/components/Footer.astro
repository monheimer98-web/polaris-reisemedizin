---
/**
 * Globale Fußzeile: Marke, Navigationsspalten, Kontakt & Sprechzeiten,
 * rechtliche Links sowie medizinischer Disclaimer und Quellenhinweis.
 */
import { primaryNav, footerInfoNav, legalNav, BOOKING_PATH } from '../config/nav';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { site } from '../config/site';
import type { UiKey } from '../i18n/ui';
import Logo from './Logo.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

const servicesItem = primaryNav.find((i) => i.path === '/leistungen');
const diseasesItem = primaryNav.find((i) => i.path === '/krankheitsbilder');
const infoLinks = footerInfoNav;
---

<footer class="mt-24 border-t border-line bg-petrol-900 text-cream/80">
  <div class="u-container py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
      {/* Marke */}
      <div class="max-w-xs">
        <div class="flex items-center gap-2.5">
          <Logo class="h-10 w-10" />
          <span class="font-display text-xl font-semibold text-cream">{site.brand.name}</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-cream/70">{site.brand.tagline[lang]}</p>
        <p class="mt-2 text-sm leading-relaxed text-cream/60">{t('home.badgeYellowFever')}</p>
      </div>

      {/* Leistungen */}
      <nav aria-label={t('footer.servicesTitle')}>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.servicesTitle')}</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            servicesItem?.children?.map((child) => (
              <li>
                <a href={getLocalizedPath(child.path, lang)} class="text-cream/75 transition-colors hover:text-cream">
                  {t(child.labelKey as UiKey)}
                </a>
              </li>
            ))
          }
          <li>
            <a href={getLocalizedPath(BOOKING_PATH, lang)} class="text-cream/75 transition-colors hover:text-cream">
              {t('nav.booking')}
            </a>
          </li>
        </ul>
      </nav>

      {/* Information */}
      <nav aria-label={t('footer.infoTitle')}>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.infoTitle')}</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            diseasesItem?.children?.map((child) => (
              <li>
                <a href={getLocalizedPath(child.path, lang)} class="text-cream/75 transition-colors hover:text-cream">
                  {t(child.labelKey as UiKey)}
                </a>
              </li>
            ))
          }
          {
            infoLinks.map((item) => (
              <li>
                <a href={getLocalizedPath(item.path, lang)} class="text-cream/75 transition-colors hover:text-cream">
                  {t(item.labelKey as UiKey)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Kontakt & Sprechzeiten */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.contactTitle')}</h2>
        <address class="mt-4 space-y-1 text-sm not-italic text-cream/75">
          <p>{site.contact.street}</p>
          <p>{site.contact.zip} {site.contact.city}</p>
          {site.contact.addressNote && <p class="text-cream/55">{site.contact.addressNote[lang]}</p>}
          <p class="pt-2">
            <a href={site.contact.phoneHref} class="transition-colors hover:text-cream">{site.contact.phone}</a>
          </p>
          <p>
            <a href={site.contact.emailHref} class="transition-colors hover:text-cream">{site.contact.email}</a>
          </p>
        </address>

        <h3 class="mt-6 text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.hoursTitle')}</h3>
        <dl class="mt-3 space-y-1 text-sm text-cream/75">
          {
            site.openingHours.map((row) => (
              <div class="flex justify-between gap-4">
                <dt class="text-cream/60">{row.day[lang]}</dt>
                <dd class="text-right">{row.hours[lang]}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    {/* Hinweise: Disclaimer + Quellen */}
    <div class="mt-14 grid gap-6 border-t border-cream/15 pt-8 sm:grid-cols-2">
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.disclaimerTitle')}</h2>
        <p class="mt-3 text-xs leading-relaxed text-cream/55">{t('footer.disclaimer')}</p>
      </div>
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold-300">{t('footer.legalTitle')}</h2>
        <p class="mt-3 text-xs leading-relaxed text-cream/55">{t('footer.sourcesNote')}</p>
      </div>
    </div>
  </div>

  {/* Bottom-Bar */}
  <div class="border-t border-cream/15">
    <div class="u-container flex flex-col items-center justify-between gap-4 py-6 text-xs text-cream/55 sm:flex-row">
      <p>© {year} {site.brand.name}. {t('footer.rights')}</p>
      <nav aria-label={t('footer.legalTitle')}>
        <ul class="flex items-center gap-5">
          {
            legalNav.map((item) => (
              <li>
                <a href={getLocalizedPath(item.path, lang)} class="transition-colors hover:text-cream">
                  {t(item.labelKey as UiKey)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</footer>
