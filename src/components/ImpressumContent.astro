---
/**
 * Inhalt der Impressum-Seite. Selbsttragend: leitet die Sprache aus der URL ab,
 * rendert die Rahmentexte/Beschriftungen aus `impressumPage` und setzt die
 * konkreten Pflichtangaben nach § 5 DDG zentral aus `site.ts` ein (einzige
 * Quelle der Wahrheit). Platzhalter-URLs (z. B. der Kammer) werden bewusst als
 * Klartext statt als Link ausgegeben, solange sie nicht durch eine echte URL
 * ersetzt wurden – so entstehen keine toten Links.
 */
import { getLangFromUrl, useTranslations, formatReviewDate } from '../i18n/utils';
import { site } from '../config/site';
import { impressumPage as page } from '../data/impressum';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = page.labels;

/** Approbierte Ärzt:innen der Praxis – berufsrechtlich verantwortlich. */
const physicians = site.team.filter((member) => member.isPhysician);

/** Nur echte URLs verlinken; Platzhalter („[PLATZHALTER: …]") bleiben Klartext. */
const isUrl = (value: string) => /^https?:\/\//.test(value);

/**
 * Berufshaftpflicht nur ausweisen, wenn ein echter Versicherer hinterlegt ist.
 * Die Nennung im Impressum ist für ärztliche Heilbehandlung nicht zwingend; ist
 * `insurer` leer (oder ein Platzhalter), bleibt der Abschnitt aus.
 */
const hasInsurer = (() => {
  const v = site.liabilityInsurance.insurer.trim();
  return v !== '' && !v.startsWith('[');
})();
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
        <p class="mt-6 text-sm text-ink-soft">
          <span class="font-medium text-ink">{t('legal.lastUpdated')}</span>
          {formatReviewDate(page.lastUpdated, lang)}
        </p>
      </div>
    </div>
  </header>

  {/* Pflichtangaben + Boilerplate */}
  <section class="u-container-narrow py-14 sm:py-16">
    <div class="space-y-12">
      {/* Diensteanbieter */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.providerHeading[lang]}</h2>
        <address class="mt-4 space-y-0.5 not-italic leading-relaxed text-ink-soft">
          <p class="font-semibold text-petrol-900">{site.brand.legalName}</p>
          <p>{site.contact.street}</p>
          {site.contact.addressNote && <p>{site.contact.addressNote[lang]}</p>}
          <p>{site.contact.zip} {site.contact.city}</p>
          <p>{site.contact.country[lang]}</p>
        </address>
      </section>

      {/* Vertretungsberechtigt / verantwortlicher Arzt */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.responsibleHeading[lang]}</h2>
        <ul class="mt-4 space-y-1 leading-relaxed text-ink-soft">
          {
            physicians.map((member) => (
              <li>
                <span class="font-semibold text-petrol-900">{member.name}</span>
                <span class="text-ink-soft"> — {member.role[lang]}</span>
              </li>
            ))
          }
        </ul>
        <p class="mt-3 text-sm leading-relaxed text-ink-soft">{l.responsibleNote[lang]}</p>
      </section>

      {/* Kontakt */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.contactHeading[lang]}</h2>
        <dl class="mt-4 space-y-3">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.phoneLabel[lang]}</dt>
            <dd class="mt-1">
              <a
                href={site.contact.phoneHref}
                class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
              >
                {site.contact.phone}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.emailLabel[lang]}</dt>
            <dd class="mt-1">
              <a
                href={site.contact.emailHref}
                class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
              >
                {site.contact.email}
              </a>
            </dd>
          </div>
        </dl>
      </section>

      {/* Berufsbezeichnung & berufsrechtliche Regelungen */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.professionHeading[lang]}</h2>
        <dl class="mt-4 space-y-4">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.jobTitleLabel[lang]}</dt>
            <dd class="mt-1 leading-relaxed text-ink-soft">
              {site.professional.jobTitle[lang]} ({site.professional.jobTitleCountry[lang]})
            </dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.chamberLabel[lang]}</dt>
            <dd class="mt-1 leading-relaxed text-ink-soft">
              <p>{site.professional.chamberName}</p>
              {
                isUrl(site.professional.chamberUrl) && (
                  <p>
                    <a
                      href={site.professional.chamberUrl}
                      class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {site.professional.chamberUrl}
                    </a>
                  </p>
                )
              }
              <p class="mt-1 text-sm">{l.chamberNote[lang]}</p>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.rulesLabel[lang]}</dt>
            <dd class="mt-1 leading-relaxed text-ink-soft">
              <p>{l.rulesText[lang]}</p>
              {
                isUrl(site.professional.professionalRulesUrl) && (
                  <p class="mt-1">
                    <a
                      href={site.professional.professionalRulesUrl}
                      class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {site.professional.professionalRulesUrl}
                    </a>
                  </p>
                )
              }
            </dd>
          </div>
        </dl>
      </section>

      {/* Zulassung als Gelbfieberimpfstelle */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.yellowFeverHeading[lang]}</h2>
        <p class="mt-4 leading-relaxed text-ink-soft">{l.yellowFeverIntro[lang]}</p>
        <dl class="mt-4 space-y-3">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.yellowFeverRefLabel[lang]}</dt>
            <dd class="mt-1 leading-relaxed text-ink-soft">{site.yellowFever.authorizationRef}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.yellowFeverAuthorityLabel[lang]}</dt>
            <dd class="mt-1 leading-relaxed text-ink-soft">{site.yellowFever.authority}</dd>
          </div>
        </dl>
      </section>

      {/* Berufshaftpflichtversicherung — nur, wenn ein echter Versicherer hinterlegt ist */}
      {
        hasInsurer && (
          <section>
            <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.insuranceHeading[lang]}</h2>
            <dl class="mt-4 space-y-3">
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.insurerLabel[lang]}</dt>
                <dd class="mt-1 leading-relaxed text-ink-soft">{site.liabilityInsurance.insurer}</dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wider text-gold-700">{l.insuranceScopeLabel[lang]}</dt>
                <dd class="mt-1 leading-relaxed text-ink-soft">{site.liabilityInsurance.scope[lang]}</dd>
              </div>
            </dl>
          </section>
        )
      }

      {/* Umsatzsteuer */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.vatHeading[lang]}</h2>
        {
          site.professional.vatId ? (
            <p class="mt-4 leading-relaxed text-ink-soft">
              <span class="font-semibold text-petrol-900">USt-IdNr.:</span> {site.professional.vatId}
            </p>
          ) : (
            <p class="mt-4 leading-relaxed text-ink-soft">{l.vatNote[lang]}</p>
          )
        }
      </section>

      {/* Redaktionell verantwortlich */}
      <section>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.editorHeading[lang]}</h2>
        <ul class="mt-4 space-y-1 leading-relaxed text-ink-soft">
          {
            physicians.map((member) => (
              <li class="font-semibold text-petrol-900">{member.name}</li>
            ))
          }
        </ul>
        <p class="mt-3 text-sm leading-relaxed text-ink-soft">{l.editorNote[lang]}</p>
      </section>

      {/* Boilerplate-Prosa */}
      {
        page.blocks.map((block) => (
          <section id={block.id}>
            <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{block.heading[lang]}</h2>
            <div class="mt-4 space-y-3 leading-relaxed text-ink-soft">
              {block.body[lang].map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>
        ))
      }

      {/* Abschluss-Hinweis (Mustercharakter) */}
      <p class="rounded-2xl border border-line bg-sand/50 px-5 py-4 text-sm leading-relaxed text-ink-soft sm:px-6">
        {page.closingNote[lang]}
      </p>
    </div>
  </section>
</article>
