---
/**
 * Startseiten-Hero „Nachthimmel mit Polarstern".
 *
 * Premium-Auftritt in Markenfarben: tiefer Petrol-Nachthimmel mit einem
 * animierten Sternenfeld (Canvas), dem leuchtenden Leitstern (Polaris) als
 * Markenmotiv, feinen Kompass-/Konstellationslinien und gelegentlichen
 * Sternschnuppen. Inhalt (Eyebrow, Titel, Lead, CTAs, Vertrauens-Badge) liegt
 * darüber. Sprache aus der URL.
 *
 * Bewusst zurückhaltend & seriös (Medizin, HWG-konform): langsame Bewegung,
 * dezente Akzente. Vollständig `prefers-reduced-motion`-tauglich — dann bleibt
 * ein ruhiger, statischer Sternenhimmel stehen. Das Canvas pausiert außerhalb
 * des Viewports und bei inaktivem Tab (Performance/Akku).
 */
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { BOOKING_PATH } from '../config/nav';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative isolate overflow-hidden bg-petrol-900 text-cream">
  {/* Tiefer Nachthimmel-Verlauf */}
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(130% 120% at 78% -10%, #12454d 0%, #0b333a 42%, #072429 72%, #05191d 100%);"
    aria-hidden="true"
  >
  </div>

  {/* Animiertes Sternenfeld (dekorativ) */}
  <canvas class="hero-starfield pointer-events-none absolute inset-0 -z-10 h-full w-full" data-starfield aria-hidden="true"></canvas>

  {/* Weiche Farbschleier für Tiefe */}
  <div class="pointer-events-none absolute -right-24 -top-40 -z-10 h-[34rem] w-[34rem] rounded-full bg-petrol-400/20 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-24 -z-10 h-[26rem] w-[26rem] rounded-full bg-gold-500/10 blur-3xl" aria-hidden="true"></div>

  {/* Leitstern (Polaris) — Kompassstern im Sternfeld, ab lg sichtbar */}
  <div class="pointer-events-none absolute top-1/2 right-[-6rem] hidden -translate-y-1/2 lg:block xl:right-[-1rem]" aria-hidden="true">
    <div class="hero-polaris relative">
      {/* Warmer Lichthof hinter dem Stern */}
      <div
        class="hero-polaris-glow absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full xl:h-96 xl:w-96"
        style="background: radial-gradient(circle, rgba(201,162,75,0.30) 0%, rgba(201,162,75,0.10) 35%, rgba(201,162,75,0) 70%);"
      >
      </div>
      <svg class="hero-polaris-svg relative h-[30rem] w-[30rem] xl:h-[36rem] xl:w-[36rem]" viewBox="0 0 460 460" fill="none">
        {/* Kompass-/Umlaufringe */}
        <circle cx="230" cy="230" r="178" stroke="currentColor" class="text-petrol-300/25" stroke-width="1.2" />
        <g stroke="currentColor" class="text-gold-300/45" fill="none" stroke-linecap="round">
          <circle cx="230" cy="230" r="150" stroke-width="1.4" stroke-dasharray="0 10" />
          <circle cx="230" cy="230" r="98" stroke-width="1.1" stroke-dasharray="2 9" />
        </g>
        {/* Feine Konstellationslinien zum Leitstern */}
        <g stroke="currentColor" class="text-gold-200/25" stroke-width="1" stroke-linecap="round">
          <path d="M230 230 L96 150" />
          <path d="M230 230 L372 96" />
          <path d="M230 230 L150 386" />
        </g>
        {/* Großer Leitstern — Vier-Strahl-Kompassstern mit leuchtendem Kern */}
        <path
          d="M230 132 L253 207 L328 230 L253 253 L230 328 L207 253 L132 230 L207 207 Z"
          fill="currentColor"
          class="hero-star-core text-gold-300"
        />
        <path
          d="M230 168 L244 216 L292 230 L244 244 L230 292 L216 244 L168 230 L216 216 Z"
          fill="currentColor"
          class="text-cream/90"
        />
        <circle cx="230" cy="230" r="4.5" fill="currentColor" class="text-cream" />
        {/* Begleitsterne */}
        <circle cx="372" cy="96" r="3.2" fill="currentColor" class="hero-twinkle text-gold-200" style="--d:0s" />
        <circle cx="96" cy="150" r="2.6" fill="currentColor" class="hero-twinkle text-cream/80" style="--d:1.1s" />
        <circle cx="150" cy="386" r="2.6" fill="currentColor" class="hero-twinkle text-gold-200" style="--d:2.2s" />
      </svg>
    </div>
  </div>

  <div class="u-container relative py-24 sm:py-32 lg:py-36">
    <div class="max-w-3xl">
      <p class="eyebrow !text-gold-300">
        <span class="rule-gold"></span>
        {t('home.eyebrow')}
      </p>
      <h1 class="mt-5 text-balance text-4xl font-semibold text-white sm:text-5xl lg:text-6xl">{t('home.heroTitle')}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-cream/80">{t('home.heroLead')}</p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href={getLocalizedPath(BOOKING_PATH, lang)} class="btn-gold shadow-[0_10px_30px_-8px_rgba(201,162,75,0.55)]" aria-label={t('cta.bookAria')}>
          {t('cta.book')}
        </a>
        <a
          href={getLocalizedPath('/leistungen', lang)}
          class="inline-flex items-center justify-center gap-2 rounded-full border border-cream/25 bg-white/[0.04] px-6 py-3 text-sm font-semibold leading-none text-cream backdrop-blur-sm transition-colors duration-200 hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-400"
        >
          {t('cta.services')}
        </a>
      </div>

      <div class="mt-10 inline-flex items-center gap-3 rounded-full border border-cream/15 bg-white/[0.06] px-4 py-2.5 backdrop-blur-sm">
        <svg class="h-5 w-5 shrink-0 text-gold-300" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 1.5l6.5 2.4v4.3c0 4.1-2.8 7.3-6.5 8.3-3.7-1-6.5-4.2-6.5-8.3V3.9L10 1.5z" fill="currentColor" opacity="0.18" />
          <path d="M10 1.5l6.5 2.4v4.3c0 4.1-2.8 7.3-6.5 8.3-3.7-1-6.5-4.2-6.5-8.3V3.9L10 1.5z" stroke="currentColor" stroke-width="1.3" />
          <path d="M7 10l2 2 4-4.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="text-sm font-medium text-cream">{t('home.badgeYellowFever')}</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Sanftes Pulsieren des Lichthofs hinter dem Leitstern. */
  @keyframes heroGlowPulse {
    0%, 100% { opacity: 0.75; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }
  .hero-polaris-glow {
    animation: heroGlowPulse 6.5s ease-in-out infinite;
  }
  /* Leichtes Atmen des Sternkerns (eigene Keyframes ohne Translate). */
  @keyframes heroCorePulse {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }
  .hero-star-core {
    animation: heroCorePulse 6.5s ease-in-out infinite;
  }
  /* Funkeln der Begleitsterne (versetzt über --d). */
  @keyframes heroTwinkle {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 1; }
  }
  .hero-twinkle {
    animation: heroTwinkle 3.4s ease-in-out infinite;
    animation-delay: var(--d, 0s);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-polaris-glow,
    .hero-star-core,
    .hero-twinkle {
      animation: none;
    }
  }
</style>

<script>
  // Leichtgewichtiges Sternenfeld auf <canvas>. Rein dekorativ. Achtet auf
  // prefers-reduced-motion (dann statisch), pausiert außerhalb des Viewports
  // (IntersectionObserver) und bei verstecktem Tab (visibilitychange).
  type Star = {
    x: number;
    y: number;
    r: number;
    base: number; // Grund-Helligkeit
    amp: number; // Funkel-Amplitude
    spd: number; // Funkel-Tempo
    ph: number; // Phase
    vx: number; // sehr langsame Drift
    vy: number;
    gold: boolean;
  };

  type Shooting = { x: number; y: number; vx: number; vy: number; life: number; len: number } | null;

  function initStarfield(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let w = 0;
    let h = 0;
    let dpr = 1;
    let stars: Star[] = [];
    let raf = 0;
    let running = false;
    let last = 0;
    let shoot: Shooting = null;
    let nextShoot = 4000;
    let sinceShoot = 0;
    let isVisible = true;

    function build() {
      const area = w * h;
      const count = Math.max(40, Math.min(170, Math.round(area / 8200)));
      stars = new Array(count).fill(0).map(() => {
        const gold = Math.random() < 0.22;
        return {
          x: Math.random() * w,
          y: Math.random() * h,
          r: 0.35 + Math.random() * 1.4,
          base: 0.25 + Math.random() * 0.5,
          amp: 0.15 + Math.random() * 0.45,
          spd: 0.4 + Math.random() * 1.1,
          ph: Math.random() * Math.PI * 2,
          vx: (Math.random() - 0.5) * 0.02,
          vy: (Math.random() - 0.5) * 0.02,
          gold,
        };
      });
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      w = Math.max(1, Math.round(rect.width));
      h = Math.max(1, Math.round(rect.height));
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      build();
      drawStatic();
    }

    function paintStar(s: Star, alpha: number) {
      const a = Math.max(0, Math.min(1, alpha));
      ctx!.beginPath();
      ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx!.fillStyle = s.gold ? `rgba(233, 210, 147, ${a})` : `rgba(247, 245, 240, ${a})`;
      ctx!.fill();
    }

    function drawStatic() {
      ctx!.clearRect(0, 0, w, h);
      for (const s of stars) paintStar(s, s.base + s.amp * 0.4);
    }

    function frame(now: number) {
      if (!running) return;
      const dt = Math.min(50, now - last || 16);
      last = now;
      ctx!.clearRect(0, 0, w, h);

      const tSec = now / 1000;
      for (const s of stars) {
        s.x += s.vx;
        s.y += s.vy;
        if (s.x < -2) s.x = w + 2;
        else if (s.x > w + 2) s.x = -2;
        if (s.y < -2) s.y = h + 2;
        else if (s.y > h + 2) s.y = -2;
        const tw = s.base + s.amp * Math.sin(tSec * s.spd + s.ph);
        paintStar(s, tw);
      }

      // Sternschnuppe – selten, dezent.
      sinceShoot += dt;
      if (!shoot && sinceShoot > nextShoot) {
        sinceShoot = 0;
        nextShoot = 7000 + Math.random() * 9000;
        const fromLeft = Math.random() < 0.5;
        const sx = fromLeft ? Math.random() * w * 0.4 : w * (0.6 + Math.random() * 0.4);
        const sy = Math.random() * h * 0.4;
        const dir = fromLeft ? 1 : -1;
        const speed = 0.35 + Math.random() * 0.25;
        shoot = { x: sx, y: sy, vx: dir * speed, vy: speed * 0.5, life: 0, len: 90 + Math.random() * 70 };
      }
      if (shoot) {
        shoot.life += dt;
        shoot.x += shoot.vx * dt;
        shoot.y += shoot.vy * dt;
        const fade = Math.max(0, 1 - shoot.life / 900);
        const tailX = shoot.x - shoot.vx * shoot.len;
        const tailY = shoot.y - shoot.vy * shoot.len;
        const grad = ctx!.createLinearGradient(shoot.x, shoot.y, tailX, tailY);
        grad.addColorStop(0, `rgba(247, 245, 240, ${0.9 * fade})`);
        grad.addColorStop(1, 'rgba(247, 245, 240, 0)');
        ctx!.strokeStyle = grad;
        ctx!.lineWidth = 1.6;
        ctx!.lineCap = 'round';
        ctx!.beginPath();
        ctx!.moveTo(shoot.x, shoot.y);
        ctx!.lineTo(tailX, tailY);
        ctx!.stroke();
        if (shoot.life > 950 || shoot.x < -120 || shoot.x > w + 120 || shoot.y > h + 120) shoot = null;
      }

      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (reduce || running) return;
      running = true;
      last = performance.now();
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }

    resize();

    let resizeTimer = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(resize, 150);
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if (isVisible) start();
    });

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          isVisible = e.isIntersecting;
          if (isVisible && !document.hidden) start();
          else stop();
        }
      },
      { threshold: 0 },
    );
    io.observe(canvas);
  }

  const canvases = document.querySelectorAll<HTMLCanvasElement>('[data-starfield]');
  canvases.forEach((c) => initStarfield(c));
</script>
