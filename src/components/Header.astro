---
/**
 * Globale Kopfzeile: Marke, Hauptnavigation (mit Untermenüs), Sprachumschalter
 * und Buchungs-CTA. Mobil als zugängliches Off-Canvas-Menü.
 */
import { primaryNav, BOOKING_PATH } from '../config/nav';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { site } from '../config/site';
import type { UiKey } from '../i18n/ui';
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const homeHref = getLocalizedPath('/', lang);
const bookingHref = getLocalizedPath(BOOKING_PATH, lang);

function isActive(path: string): boolean {
  const localized = (getLocalizedPath(path, lang).replace(/\/+$/, '') || '/');
  if (localized === '/') return currentPath === '/';
  return currentPath === localized || currentPath.startsWith(localized + '/');
}
---

<a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-petrol-800 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-cream">
  {t('skip.toContent')}
</a>

<header class="sticky top-0 z-40 border-b border-petrol-100/70 bg-gradient-to-b from-petrol-50/90 to-cream/85 backdrop-blur-md">
  {/* Feine goldene Markenkante — dezenter Premium-Akzent */}
  <div class="h-[3px] w-full bg-gradient-to-r from-gold-300/0 via-gold-400 to-gold-300/0" aria-hidden="true"></div>
  <div class="u-container flex h-16 items-center justify-between gap-4 sm:h-20">
    {/* Marke */}
    <a href={homeHref} class="group flex items-center gap-2.5" aria-label={`${site.brand.name} — ${t('nav.home')}`}>
      <Logo class="h-9 w-9 shrink-0 sm:h-10 sm:w-10" />
      <span class="flex flex-col leading-none">
        <span class="font-display text-lg font-semibold tracking-tight text-petrol-900 sm:text-xl">{site.brand.name}</span>
        <span class="hidden text-[0.66rem] font-medium uppercase tracking-[0.16em] text-petrol-500 sm:block">
          {site.brand.tagline[lang]}
        </span>
      </span>
    </a>

    {/* Desktop-Navigation — erst ab xl (≥1280px), da die achtteilige, zweisprachige
        Leiste (Marke + Tagline + Untermenüs + Sprache + CTA) darunter zu breit wird
        und im EN-Layout sonst überliefe. Zwischen lg und xl greift das Off-Canvas-Menü. */}
    <nav class="hidden items-center gap-1 xl:flex" aria-label={t('header.primaryNav')}>
      {
        primaryNav.map((item) =>
          item.children?.length ? (
            <div class="group relative">
              <a
                href={getLocalizedPath(item.path, lang)}
                class:list={[
                  'inline-flex items-center gap-1 whitespace-nowrap rounded-full px-3.5 py-2 text-sm font-medium transition-colors hover:bg-white',
                  isActive(item.path) ? 'text-petrol-900' : 'text-ink-soft hover:text-petrol-900',
                ]}
                aria-current={isActive(item.path) ? 'page' : undefined}
              >
                {t(item.labelKey as UiKey)}
                <svg class="h-3.5 w-3.5 opacity-60 transition-transform group-hover:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
              <div class="invisible absolute left-0 top-full z-30 min-w-[15rem] pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <ul class="overflow-hidden rounded-2xl border border-line bg-white p-1.5 shadow-[var(--shadow-card)]">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={getLocalizedPath(child.path, lang)}
                        class:list={[
                          'block rounded-xl px-3.5 py-2.5 text-sm transition-colors hover:bg-cream',
                          isActive(child.path) ? 'font-semibold text-petrol-900' : 'text-ink-soft hover:text-petrol-900',
                        ]}
                        aria-current={isActive(child.path) ? 'page' : undefined}
                      >
                        {t(child.labelKey as UiKey)}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={getLocalizedPath(item.path, lang)}
              class:list={[
                'whitespace-nowrap rounded-full px-3.5 py-2 text-sm font-medium transition-colors hover:bg-white',
                isActive(item.path) ? 'text-petrol-900' : 'text-ink-soft hover:text-petrol-900',
              ]}
              aria-current={isActive(item.path) ? 'page' : undefined}
            >
              {t(item.labelKey as UiKey)}
            </a>
          )
        )
      }
    </nav>

    {/* Rechts: Sprache + CTA + Mobile-Toggle */}
    <div class="flex items-center gap-2 sm:gap-3">
      <div class="hidden sm:block">
        <LanguageSwitcher />
      </div>
      <a href={bookingHref} class="btn-gold hidden h-10 px-5 sm:inline-flex" aria-label={t('cta.bookAria')}>
        {t('cta.book')}
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line text-petrol-800 transition-colors hover:bg-white xl:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label={t('header.openMenu')}
        data-label-open={t('header.openMenu')}
        data-label-close={t('header.closeMenu')}
      >
        <svg class="menu-icon-open h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
        <svg class="menu-icon-close hidden h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile-Menü — Akkordeon: Untermenüs sind eingeklappt und per Pfeil aufklappbar,
      damit die lange Liste (u. a. 12 Krankheitsbilder) kompakt und übersichtlich bleibt. */}
  <div id="mobile-menu" class="hidden border-t border-line bg-cream xl:hidden">
    <nav class="u-container flex flex-col py-2" aria-label={t('header.primaryNav')}>
      {
        primaryNav.map((item, i) => (
          <div class="border-b border-line/50 last:border-b-0">
            {item.children?.length ? (
              <div>
                <div class="flex items-center gap-1">
                  <a
                    href={getLocalizedPath(item.path, lang)}
                    class:list={[
                      'flex-1 rounded-lg px-2 py-3 text-[0.95rem] font-semibold transition-colors',
                      isActive(item.path) ? 'text-petrol-900' : 'text-ink hover:text-petrol-900',
                    ]}
                    aria-current={isActive(item.path) ? 'page' : undefined}
                  >
                    {t(item.labelKey as UiKey)}
                  </a>
                  <button
                    type="button"
                    class="submenu-toggle inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-petrol-500 transition-colors hover:bg-white hover:text-petrol-800"
                    aria-expanded="false"
                    aria-controls={`submenu-${i}`}
                    aria-label={t('header.toggleSubmenu')}
                  >
                    <svg class="submenu-chevron h-4 w-4 transition-transform duration-200" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>
                </div>
                <div id={`submenu-${i}`} class="submenu hidden">
                  <ul class="mb-2 ml-3 flex flex-col border-l border-petrol-100 pl-3">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={getLocalizedPath(child.path, lang)}
                          class:list={[
                            'block rounded-lg px-2 py-2 text-sm transition-colors',
                            isActive(child.path) ? 'font-semibold text-petrol-900' : 'text-ink-soft hover:text-petrol-900',
                          ]}
                          aria-current={isActive(child.path) ? 'page' : undefined}
                        >
                          {t(child.labelKey as UiKey)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <a
                href={getLocalizedPath(item.path, lang)}
                class:list={[
                  'block rounded-lg px-2 py-3 text-[0.95rem] font-semibold transition-colors',
                  isActive(item.path) ? 'text-petrol-900' : 'text-ink hover:text-petrol-900',
                ]}
                aria-current={isActive(item.path) ? 'page' : undefined}
              >
                {t(item.labelKey as UiKey)}
              </a>
            )}
          </div>
        ))
      }
      <div class="mt-4 flex items-center justify-between gap-3">
        <LanguageSwitcher />
        <a href={bookingHref} class="btn-gold h-11 flex-1 justify-center" aria-label={t('cta.bookAria')}>
          {t('cta.book')}
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  // Bewusst is:inline: NICHT durch Vite/Rolldown geschleust. Unter Astro 6 +
  // rolldown-vite zerlegt der React-Refresh-Wrapper sonst dieses gehostete
  // Skript („Missing field moduleType"), wodurch das Menü ohne Funktion bliebe.
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    var iconOpen = toggle.querySelector('.menu-icon-open');
    var iconClose = toggle.querySelector('.menu-icon-close');

    function setOpen(open) {
      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? toggle.dataset.labelClose || '' : toggle.dataset.labelOpen || '');
      if (iconOpen) iconOpen.classList.toggle('hidden', open);
      if (iconClose) iconClose.classList.toggle('hidden', !open);
    }

    toggle.addEventListener('click', function () {
      setOpen(menu.classList.contains('hidden'));
    });

    // Untermenüs als Akkordeon auf-/zuklappen (Pfeil dreht sich).
    menu.querySelectorAll('.submenu-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('aria-controls');
        var panel = id ? document.getElementById(id) : null;
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        if (panel) panel.classList.toggle('hidden', open);
        var chevron = btn.querySelector('.submenu-chevron');
        if (chevron) chevron.classList.toggle('rotate-180', !open);
      });
    });

    // Beim Wechsel auf Desktop-Breite (xl) das mobile Menü schließen.
    window.matchMedia('(min-width: 1280px)').addEventListener('change', function (e) {
      if (e.matches) setOpen(false);
    });
  })();
</script>
