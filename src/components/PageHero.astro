---
/**
 * Wiederverwendbarer Seiten-Hero für Übersichts- und Sonderseiten: warme
 * Marken-Wäsche (Petrol→Creme→Sand) + dezentes Globus-/Meridian-Motiv,
 * Eyebrow + H1 + Lead. Über den Default-Slot lassen sich Zusatzangaben
 * (z. B. „Inhaltlich geprüft"-Datum oder Badges) unter dem Lead ergänzen.
 */
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  /** Globus-/Meridian-Motiv anzeigen (Default true). */
  motif?: boolean;
}

const { eyebrow, title, lead, motif = true } = Astro.props;
---

<header class="relative overflow-hidden border-b border-petrol-100/70">
  {/* Warme Marken-Wäsche statt flachem Sand */}
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-petrol-50/80 via-cream to-sand/40" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 -top-28 h-80 w-80 rounded-full bg-petrol-100/45 blur-3xl" aria-hidden="true"></div>
  {
    motif && (
      <div class="pointer-events-none absolute top-1/2 right-[-2.5rem] hidden -translate-y-1/2 lg:block" aria-hidden="true">
        <svg class="h-72 w-72 text-petrol-200/70 xl:h-80 xl:w-80" viewBox="0 0 240 240" fill="none">
          {/* Feiner Petrol-Ring */}
          <circle cx="120" cy="120" r="98" stroke="currentColor" stroke-width="1.1" />
          {/* Goldener Punkt-Kranz (Kompass-Teilung) */}
          <circle cx="120" cy="120" r="78" stroke="currentColor" class="text-gold-300" stroke-width="1.1" stroke-linecap="round" stroke-dasharray="0 6.5" />
          {/* Leitstern — Vier-Strahl-Kompassstern */}
          <path d="M120 62 L135 105 L178 120 L135 135 L120 178 L105 135 L62 120 L105 105 Z" fill="currentColor" />
          <circle cx="120" cy="120" r="3" fill="currentColor" class="text-gold-400" />
          {/* Begleitsterne */}
          <path d="M44 52 L46.3 57.7 L52 60 L46.3 62.3 L44 68 L41.7 62.3 L36 60 L41.7 57.7 Z" fill="currentColor" class="text-gold-300" />
          <path d="M200 175.5 L201.9 180.1 L206.5 182 L201.9 183.9 L200 188.5 L198.1 183.9 L193.5 182 L198.1 180.1 Z" fill="currentColor" class="text-gold-300" />
        </svg>
      </div>
    )
  }
  <div class="u-container relative py-14 sm:py-20">
    <div class="max-w-3xl">
      {Astro.slots.has('breadcrumb') && <div class="mb-6"><slot name="breadcrumb" /></div>}
      <p class="eyebrow"><span class="rule-gold"></span>{eyebrow}</p>
      <h1 class="mt-5 text-4xl sm:text-5xl">{title}</h1>
      {lead && <p class="mt-5 text-lg leading-relaxed text-ink-soft">{lead}</p>}
      <slot />
    </div>
  </div>
</header>
