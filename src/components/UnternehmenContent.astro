---
/**
 * Inhalt der Seite „Reisemedizin für Unternehmen" (B2B). Selbsttragend:
 * Sprache aus der URL, Inhalt aus `unternehmenPage`. Schließt mit einem
 * Kontakt-Band (→ /kontakt) statt der allgemeinen Termin-CTA, da B2B-Anfragen
 * persönlich abgestimmt werden.
 */
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';
import { unternehmenPage as page } from '../data/unternehmen';

const lang = getLangFromUrl(Astro.url);
const contactHref = getLocalizedPath('/kontakt', lang);
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
      </div>
    </div>
  </header>

  {/* Einleitung */}
  <section class="u-container py-14 sm:py-16">
    <div class="max-w-3xl space-y-4 text-lg leading-relaxed text-ink-soft">
      {page.intro[lang].map((paragraph) => <p>{paragraph}</p>)}
    </div>

    {/* Leistungen */}
    <h2 class="mt-12 font-display text-2xl text-petrol-900 sm:mt-14 sm:text-3xl">{page.servicesHeading[lang]}</h2>
    <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        page.services.map((service) => (
          <li class="card flex flex-col gap-3">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-petrol-800/[0.06] text-petrol-700">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M5 12.5l4.2 4.2L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-petrol-900">{service.title[lang]}</h3>
            <p class="text-sm leading-relaxed text-ink-soft">{service.text[lang]}</p>
          </li>
        ))
      }
    </ul>
  </section>

  {/* Ablauf (Band) */}
  <section class="border-y border-line bg-sand/60">
    <div class="u-container py-14 sm:py-16">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.processHeading[lang]}</h2>
        <p class="mt-3 text-ink-soft">{page.processLead[lang]}</p>
      </div>

      <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          page.steps.map((step, index) => (
            <li class="card flex flex-col gap-3">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-petrol-800/[0.06] font-display text-lg text-petrol-700">
                {index + 1}
              </span>
              <h3 class="text-base font-semibold text-petrol-900">{step.title[lang]}</h3>
              <p class="text-sm leading-relaxed text-ink-soft">{step.text[lang]}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Abrechnung */}
  <section class="u-container py-14 sm:py-16">
    <div class="max-w-3xl">
      <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.billing.heading[lang]}</h2>
      <div class="mt-4 space-y-4 leading-relaxed text-ink-soft">
        {page.billing.body[lang].map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    {/* Kontakt-Band */}
    <div class="mt-12 overflow-hidden rounded-3xl bg-petrol-800 px-8 py-10 sm:mt-14 sm:px-10 sm:py-12">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-xl">
          <h2 class="font-display text-2xl text-cream sm:text-3xl">{page.contact.heading[lang]}</h2>
          <p class="mt-3 leading-relaxed text-cream/80">{page.contact.text[lang]}</p>
        </div>
        <a href={contactHref} class="btn-gold shrink-0">{page.contact.cta[lang]}</a>
      </div>
    </div>
  </section>
</article>
