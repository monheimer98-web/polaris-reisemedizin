---
/**
 * Einbettung des in der praxis-app gebauten Buchungstools (`/buchung`) als
 * responsives iframe mit nahtloser Auto-Höhe.
 *
 * ADRESSE: Bevorzugt die feste Build-Zeit-URL `embedUrl` (permanenter
 * Cloudflare-Named-Tunnel, PUBLIC_BOOKING_EMBED_URL) und baut daraus
 * `<basis>/buchung?embed=1`. Nur wenn keine feste URL gesetzt ist (LAN-/Vorschau-
 * Builds), liest ein Fallback die aktuelle Basis-Adresse zur Laufzeit aus
 * `app-url.json` (Rest der abgelösten Quick-Tunnel-Automatik).
 *
 * First-Party (eigene Praxis-Infrastruktur, kein Drittanbieter) → kein Cookie-/
 * Consent-Gate nötig. Die eingebettete Seite meldet ihre Höhe per
 * postMessage({ type: 'polaris-booking-height', height }); das Skript setzt die
 * iframe-Höhe entsprechend (kein innerer Scrollbalken). Die App erlaubt die
 * Einbettung per CSP `frame-ancestors` (Website-Origin in EMBED_ORIGINS).
 */
interface Props {
  /** Feste Buchungs-URL (…/buchung), bevorzugt. Leer → Laufzeit-Fallback app-url.json. */
  embedUrl?: string;
  /** Zugänglicher Titel des iframes (Screenreader). */
  title: string;
}

const { embedUrl = '', title } = Astro.props;
// Pfad zur selbst-aktualisierenden Adress-Datei (respektiert den Pages-Unterpfad).
const jsonUrl = `${import.meta.env.BASE_URL}app-url.json`;
---

<div class="overflow-hidden rounded-2xl border border-line bg-white shadow-[var(--shadow-card)]">
  <div
    class="booking-embed-mount"
    data-json={jsonUrl}
    data-fallback={embedUrl}
    data-title={title}>
    <div class="booking-embed-lade" role="status">Buchung wird geladen …</div>
  </div>
</div>

<script>
  // Aktuelle Server-Adresse holen und iframe bauen. Läuft im Browser der
  // Besucherin, immer frisch (Cache umgangen), damit ein Mac-Neustart die
  // Buchung nicht kaputt macht.
  const mount = document.querySelector('.booking-embed-mount');
  if (mount instanceof HTMLElement) {
    const jsonUrl = mount.dataset.json || 'app-url.json';
    const fallback = mount.dataset.fallback || '';
    const title = mount.dataset.title || 'Terminbuchung';

    function basisAus(u: string): string {
      try { return new URL(u).origin; } catch { return u.replace(/\/(buchung|mobil).*$/, ''); }
    }

    function baueIframe(basis: string) {
      const src = basis.replace(/\/+$/, '') + '/buchung?embed=1';
      let origin = '';
      try { origin = new URL(src).origin; } catch { origin = ''; }
      const frame = document.createElement('iframe');
      frame.className = 'booking-embed-frame block w-full';
      frame.title = title;
      frame.setAttribute('loading', 'lazy');
      frame.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
      frame.style.cssText = 'height:760px;border:0;';
      frame.src = src;
      mount!.replaceChildren(frame);
      window.addEventListener('message', (event) => {
        if (origin && event.origin !== origin) return;
        const data = event.data as { type?: string; height?: number } | null;
        if (data && data.type === 'polaris-booking-height' && typeof data.height === 'number') {
          frame.style.height = Math.max(480, Math.min(4000, Math.round(data.height))) + 'px';
        }
      });
    }

    function fehler() {
      mount!.innerHTML =
        '<div class="booking-embed-lade">Die Online-Buchung ist gerade nicht erreichbar. ' +
        'Bitte rufen Sie uns an oder versuchen Sie es später erneut.</div>';
    }

    function baueButton(basis: string) {
      // Kein iframe, sondern ein Button, der die Buchung direkt öffnet – für
      // kleine Bildschirme (v. a. iOS-Safari), wo die iframe-Einbettung
      // unzuverlässig ist (leerer Rahmen).
      const url = basis.replace(/\/+$/, '') + '/buchung';
      const wrap = document.createElement('div');
      wrap.className = 'booking-embed-cta';
      const text = document.createElement('p');
      text.className = 'booking-embed-cta-text';
      text.textContent = 'Terminart wählen und Wunschtermin sichern – in wenigen Schritten.';
      const link = document.createElement('a');
      link.href = url;
      link.target = '_blank';
      link.rel = 'noopener';
      link.className = 'booking-embed-cta-btn';
      link.textContent = 'Zur Online-Buchung';
      wrap.append(text, link);
      mount!.replaceChildren(wrap);
    }

    function zeige(basis: string) {
      // Auf kleinen Bildschirmen den robusten Button, sonst die iframe-Einbettung.
      if (window.matchMedia('(max-width: 767px)').matches) baueButton(basis);
      else baueIframe(basis);
    }

    if (fallback) {
      // Fester, permanenter Buchungs-Tunnel (Build-Zeit, PUBLIC_BOOKING_EMBED_URL).
      zeige(basisAus(fallback));
    } else {
      // Nur ohne feste URL (LAN-/Vorschau-Builds): Adresse zur Laufzeit aus
      // app-url.json lesen (Rest der abgelösten Quick-Tunnel-Automatik).
      fetch(jsonUrl + '?_=' + Date.now(), { cache: 'no-store' })
        .then((r) => (r.ok ? r.json() : Promise.reject()))
        .then((d) => {
          if (d && d.url) zeige(basisAus(d.url));
          else throw new Error('keine URL');
        })
        .catch(() => fehler());
    }
  }
</script>

<style>
  .booking-embed-lade {
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px;
    color: var(--color-muted, #5a6b6a);
    font-size: 0.95rem;
  }

  /* Mobiler Fallback: Button statt iframe (iOS-Safari-robust). */
  .booking-embed-cta {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    text-align: center;
    padding: 32px 24px;
  }
  .booking-embed-cta-text {
    margin: 0;
    max-width: 34ch;
    color: var(--color-muted, #5a6b6a);
    font-size: 1rem;
    line-height: 1.5;
  }
  .booking-embed-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px 30px;
    border-radius: 9999px;
    background: var(--color-petrol, #123f3a);
    color: #fff;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    box-shadow: var(--shadow-card, 0 8px 22px rgba(0, 0, 0, 0.14));
  }
  .booking-embed-cta-btn::after {
    content: '↗';
    font-size: 0.95em;
  }
  .booking-embed-cta-btn:hover {
    filter: brightness(1.08);
  }
</style>
