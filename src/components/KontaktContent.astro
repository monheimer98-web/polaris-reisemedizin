---
/**
 * Inhalt der „Kontakt & Anfahrt"-Seite. Selbsttragend: leitet die Sprache aus
 * der URL ab, rendert die Rahmentexte aus `kontaktPage` und die konkreten
 * Kontaktdaten zentral aus `site.contact`/`site.openingHours`. Die Anfahrt
 * nutzt dasselbe 2-Klick-Consent-Gate wie die Terminbuchung (`ConsentEmbed`,
 * eigener Storage-Key „map" → getrennte Einwilligung). Solange
 * `site.map.embedUrl` leer ist, erscheint ein neutraler Platzhalter samt
 * Outbound-Link „Route planen" – ganz ohne externen Request.
 */
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';
import { site } from '../config/site';
import { kontaktPage as page } from '../data/kontakt';
import ConsentEmbed from './ConsentEmbed';

const lang = getLangFromUrl(Astro.url);
const l = page.labels;
const c = page.consent;

/** Consent-Texte in der aktuellen Sprache für das React-Island auflösen. */
const labels = {
  consentTitle: c.title[lang],
  consentLead: c.lead[lang],
  consentPoints: c.points[lang],
  privacyIntro: c.privacyIntro[lang],
  providerPrivacyLabel: c.providerPrivacyLabel[lang],
  ourPrivacyLabel: c.ourPrivacyLabel[lang],
  loadButton: c.loadButton[lang],
  externalLabel: c.externalLabel[lang],
  iframeTitle: c.iframeTitle[lang],
  loadedNote: c.loadedNote[lang],
  revokeLabel: c.revokeLabel[lang],
  placeholderTitle: c.placeholderTitle[lang],
  placeholderBody: c.placeholderBody[lang],
};
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
      </div>
    </div>
  </header>

  {/* Kontaktdaten + Anfahrt */}
  <section class="u-container py-14 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:gap-14">
      {/* Kontaktangaben */}
      <div>
        <div class="max-w-prose space-y-4 text-lg leading-relaxed text-ink-soft">
          {page.intro[lang].map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <a href={getLocalizedPath('/termin', lang)} class="btn-gold mt-6 inline-flex">
          {l.bookCta[lang]}
        </a>

        <div class="mt-10 grid gap-6">
          {/* Anschrift + Kontakt */}
          <div class="card">
            <h2 class="text-base font-semibold text-petrol-900">{l.addressHeading[lang]}</h2>
            <address class="mt-3 space-y-0.5 text-sm not-italic leading-relaxed text-ink-soft">
              <p>{site.contact.street}</p>
              {site.contact.addressNote && <p>{site.contact.addressNote[lang]}</p>}
              <p>{site.contact.zip} {site.contact.city}</p>
              <p>{site.contact.country[lang]}</p>
            </address>

            <dl class="mt-5 space-y-3 text-sm">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <dt class="font-semibold uppercase tracking-wider text-gold-700">{l.phoneLabel[lang]}</dt>
                <dd>
                  <a
                    href={site.contact.phoneHref}
                    class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                  >
                    {site.contact.phone}
                  </a>
                </dd>
              </div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <dt class="font-semibold uppercase tracking-wider text-gold-700">{l.emailLabel[lang]}</dt>
                <dd>
                  <a
                    href={site.contact.emailHref}
                    class="font-medium text-petrol-800 underline decoration-gold-500 underline-offset-4 hover:text-petrol-900"
                  >
                    {site.contact.email}
                  </a>
                </dd>
              </div>
            </dl>
          </div>

          {/* Sprechzeiten */}
          <div class="card">
            <h2 class="text-base font-semibold text-petrol-900">{l.hoursHeading[lang]}</h2>
            <dl class="mt-3 divide-y divide-line/70 border-y border-line/70">
              {
                site.openingHours.map((entry) => (
                  <div class="flex items-baseline justify-between gap-6 py-2.5 text-sm">
                    <dt class="whitespace-nowrap font-medium text-petrol-900">{entry.day[lang]}</dt>
                    <dd class="whitespace-nowrap text-right tabular-nums text-ink-soft">{entry.hours[lang]}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>
      </div>

      {/* Anfahrt / Karte (2-Klick) */}
      <div>
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{l.mapHeading[lang]}</h2>
        <p class="mt-3 max-w-prose leading-relaxed text-ink-soft">{l.mapLead[lang]}</p>
        <div class="mt-6">
          <ConsentEmbed
            client:load
            storageKey="map"
            provider={site.map.provider}
            embedUrl={site.map.embedUrl}
            providerPrivacyUrl={site.map.providerPrivacyUrl}
            externalUrl={site.map.externalUrl}
            ourPrivacyUrl={getLocalizedPath('/datenschutz', lang)}
            frameClassName="h-[460px] w-full border-0"
            labels={labels}
          />
        </div>
      </div>
    </div>
  </section>
</article>
