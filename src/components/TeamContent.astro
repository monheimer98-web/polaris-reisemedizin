---
/**
 * Inhalt der „Über uns / Team"-Seite. Selbsttragend: leitet die Sprache aus
 * der URL ab (analog zu Hero/ServicesOverview), rendert die Rahmentexte aus
 * `teamPage` und die Teammitglieder aus `site.team`. Der Markenname kommt
 * aus `site.brand` (zentral änderbar). Die Porträts sind die echten
 * Originalfotos – unverändert (kein Zuschnitt, keine Farb-/Helligkeits-
 * bearbeitung); die Einpassung in den quadratischen Avatar erfolgt rein per
 * CSS (`object-cover` + `object-position` aus `member.focal`).
 */
import { getLangFromUrl, withBase } from '../i18n/utils';
import { site } from '../config/site';
import { teamPage as page } from '../data/team';

const lang = getLangFromUrl(Astro.url);
const team = site.team;
const values = page.values;
---

<article>
  {/* Hero */}
  <header class="border-b border-line bg-sand/40">
    <div class="u-container py-14 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">
          <span class="rule-gold"></span>
          {page.meta.eyebrow[lang]}
        </p>
        <h1 class="mt-5 font-display text-4xl text-petrol-900 sm:text-5xl">{page.meta.title[lang]}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{page.meta.lead[lang]}</p>
      </div>
    </div>
  </header>

  {/* Einleitung + Team */}
  <section class="u-container py-14 sm:py-16">
    <div class="max-w-3xl space-y-4 text-lg leading-relaxed text-ink-soft">
      {page.intro[lang].map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <div class="mt-12 sm:mt-14">
      <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.teamHeading[lang]}</h2>
      <p class="mt-3 max-w-2xl text-ink-soft">{page.teamLead[lang]}</p>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        {
          team.map((member) => (
            <article class="flex flex-col overflow-hidden rounded-3xl border border-line bg-white shadow-[var(--shadow-card)] sm:flex-row">
              <div class="h-60 w-full shrink-0 overflow-hidden bg-sand sm:h-auto sm:w-44 sm:self-stretch">
                <img
                  src={withBase(member.photo)}
                  alt={member.name}
                  width="512"
                  height="768"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                  style={`object-position: ${member.focal ?? 'center'}`}
                />
              </div>
              <div class="min-w-0 p-6 sm:p-7">
                <h3 class="font-display text-xl text-petrol-900 sm:text-2xl">{member.name}</h3>
                <p class="mt-1.5 text-xs font-semibold uppercase tracking-[0.14em] text-gold-700">{member.role[lang]}</p>
                <p class="mt-3 leading-relaxed text-ink-soft">{member.bio[lang]}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Unser Ansatz (Band) */}
  <section class="border-y border-line bg-sand/60">
    <div class="u-container py-14 sm:py-16">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl text-petrol-900 sm:text-3xl">{page.valuesHeading[lang]}</h2>
        <p class="mt-3 text-ink-soft">{page.valuesLead[lang]}</p>
      </div>

      <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((value) => (
            <li class="card flex flex-col gap-3">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-petrol-800/[0.06] text-petrol-700">
                {value.icon === 'book' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M12 6.5C10.3 5.2 8 4.5 5 4.7v13c3-.2 5.3.5 7 1.8 1.7-1.3 4-2 7-1.8v-13c-3-.2-5.3.5-7 1.8Z" stroke-linejoin="round" />
                    <path d="M12 6.5v12.8" stroke-linecap="round" />
                  </svg>
                )}
                {value.icon === 'shield' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M12 3l7 2.5v5.5c0 4.6-3.1 8.2-7 9.2-3.9-1-7-4.6-7-9.2V5.5L12 3z" stroke-linejoin="round" />
                    <path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {value.icon === 'calendar' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="3.5" y="5" width="17" height="15.5" rx="2.5" />
                    <path d="M3.5 9.5h17M8 3v4M16 3v4" stroke-linecap="round" />
                    <path d="M9 14.2l1.8 1.8 3.4-3.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {value.icon === 'globe' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M3 12h18" stroke-linecap="round" />
                    <path d="M12 3c2.6 2.5 2.6 15.5 0 18M12 3c-2.6 2.5-2.6 15.5 0 18" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
              </span>
              <h3 class="text-base font-semibold text-petrol-900">{value.title[lang]}</h3>
              <p class="text-sm leading-relaxed text-ink-soft">{value.text[lang]}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Über die Praxis */}
  <section class="u-container py-14 sm:py-16">
    <div class="rounded-3xl border border-line bg-white/60 p-8 shadow-[var(--shadow-soft)] sm:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.5fr)] lg:gap-12 lg:items-start">
        <div>
          <p class="eyebrow">
            <span class="rule-gold"></span>
            {site.brand.name} — {site.brand.tagline[lang]}
          </p>
          <h2 class="mt-4 font-display text-2xl text-petrol-900 sm:text-3xl">{page.practiceHeading[lang]}</h2>
        </div>
        <div class="space-y-4 leading-relaxed text-ink-soft">
          {page.practiceBody[lang].map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>
</article>
