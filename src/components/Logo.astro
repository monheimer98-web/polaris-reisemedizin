---
/**
 * Marken-Signet „Polaris": der Leitstern — goldener Vier-Strahl-Kompassstern in
 * einem feinen Ring mit goldenem Punkt-Kranz (Kompass-Teilung). Gemäß
 * Marken-Baukasten das EINZIGE Bildzeichen (keine zweite Bildmarke).
 * Rein dekorativ — der Markenname steht als Text daneben (siehe Header/Footer).
 *
 * `tone`:
 *  - 'light' (Default): auf hellen Flächen (Creme/Weiß) → Ring & Mittelpunkt Petrol.
 *  - 'dark': auf Petrol-Flächen (Footer) → Ring & Mittelpunkt Creme.
 * Stern und Punkt-Kranz bleiben in beiden Fällen Gold.
 */
interface Props {
  class?: string;
  tone?: 'light' | 'dark';
}
const { class: className = '', tone = 'light' } = Astro.props;

const ringColor = tone === 'dark' ? '#F7F5F0' : '#0E3B43';
const dotColor = ringColor;
const GOLD = '#C9A24B';
---

<svg class={className} viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
  {/* Äußerer Ring */}
  <circle cx="20" cy="20" r="15" stroke={ringColor} stroke-width="1.6"></circle>
  {/* Feiner goldener Punkt-Kranz (Kompass-Teilung) */}
  <circle cx="20" cy="20" r="12.3" stroke={GOLD} stroke-width="1" stroke-linecap="round" stroke-dasharray="0 2.4"></circle>
  {/* Leitstern — Vier-Strahl-Kompassstern */}
  <path d="M20 9.4 L22.7 17.3 L30.6 20 L22.7 22.7 L20 30.6 L17.3 22.7 L9.4 20 L17.3 17.3 Z" fill={GOLD}></path>
  {/* Mittelpunkt */}
  <circle cx="20" cy="20" r="1.15" fill={dotColor}></circle>
</svg>
