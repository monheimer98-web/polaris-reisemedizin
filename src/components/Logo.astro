---
/**
 * Marken-Signet „Polaris": Globus mit goldenem Leitbogen.
 * Rein dekorativ — der Markenname steht als Text daneben (siehe Header/Footer).
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg class={className} viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
  <rect width="40" height="40" rx="9" fill="#0E3B43"></rect>
  <g stroke="#F7F5F0" stroke-width="1.4">
    <circle cx="20" cy="20" r="10.5"></circle>
    <ellipse cx="20" cy="20" rx="4.4" ry="10.5"></ellipse>
    <line x1="9.5" y1="20" x2="30.5" y2="20"></line>
  </g>
  <path d="M20 9.5 A10.5 10.5 0 0 1 20 30.5" stroke="#C9A24B" stroke-width="1.8" stroke-linecap="round"></path>
</svg>
