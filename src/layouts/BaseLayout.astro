---
/**
 * Basis-Layout für alle Seiten: Dokumentgerüst, globales CSS, SEO-Kopf,
 * Header und Footer. Sprache wird aus der URL abgeleitet.
 */
// Selbst gehostete Schriften (DSGVO: kein Google-Fonts-CDN). Als JS-Import,
// damit Vite die woff2-Dateien bündelt und die url()-Verweise umschreibt.
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/global.css';
import { getLangFromUrl, withBase, HREFLANG } from '../i18n/utils';
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** OG-Bildpfad relativ zur Domain. */
  image?: string;
  /** Seite von der Indexierung ausnehmen. */
  noindex?: boolean;
  /** Seitenspezifische JSON-LD-Objekte (z. B. FAQPage, Physician). */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, noindex, schema } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <meta name="theme-color" content="#0E3B43" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} image={image} noindex={noindex} lang={lang} schema={schema} />
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
