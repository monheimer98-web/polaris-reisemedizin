---
/**
 * Destinations & vaccination planning (English) — overview hub.
 *
 * New structure: a planning framework (the four factors of good travel
 * prevention), a note on routine vaccination cover, card navigation to the six
 * world regions and the "required vs. recommended" classification – plus cited
 * sources and a medical disclaimer. Content from typed data modules; language
 * derived from the URL; identical to the German variant.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import RegionCard from '../../components/RegionCard.astro';
import Callout from '../../components/Callout.astro';
import SourceList from '../../components/SourceList.astro';
import CTA from '../../components/CTA.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { BOOKING_PATH } from '../../config/nav';
import { getSources } from '../../data/sources';
import { destinationsHub as hub } from '../../data/reiseziele/hub';
import { regionList } from '../../data/reiseziele/regions';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sources = getSources(hub.sourceIds);

const cardLabels = {
  examples: hub.cardLabels.examples[lang],
  topics: hub.cardLabels.topics[lang],
  cta: hub.cardLabels.cta[lang],
};

/** Strich-Piktogramme für die vier Planungsfaktoren. */
const factorIcons: Record<string, string> = {
  destination:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5"/></svg>',
  style:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M7 9a5 5 0 0 1 10 0v8a3 3 0 0 1-3 3H10a3 3 0 0 1-3-3V9Z" stroke-linejoin="round"/><path d="M9.5 9V6.5a2.5 2.5 0 0 1 5 0V9" stroke-linecap="round"/><path d="M9 14h6" stroke-linecap="round"/></svg>',
  duration:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  health:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 20s-7-4.5-7-9.5A4 4 0 0 1 12 7a4 4 0 0 1 7 3.5C19 15.5 12 20 12 20Z" stroke-linejoin="round"/><path d="M8 12h2.2l1-2 1.6 3.2 1-1.7H17" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---

<BaseLayout title={hub.meta.title[lang]} description={hub.meta.description[lang]}>
  <article>
    <PageHero eyebrow={hub.meta.eyebrow[lang]} title={hub.meta.title[lang]} lead={hub.meta.lead[lang]}>
      <a href={getLocalizedPath(BOOKING_PATH, lang)} class="btn-gold mt-8 inline-flex" aria-label={t('cta.bookAria')}>
        {t('cta.book')}
      </a>
    </PageHero>

    <div class="u-container space-y-16 py-14 sm:space-y-20 sm:py-16">
      {/* Planning framework: four factors */}
      <section aria-labelledby="planung-heading">
        <div class="max-w-3xl">
          <h2 id="planung-heading" class="font-display text-2xl text-petrol-900 sm:text-3xl">{hub.planning.heading[lang]}</h2>
          <p class="mt-3 text-ink-soft">{hub.planning.lead[lang]}</p>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {
            hub.planning.factors.map((factor) => (
              <div class="card">
                <span
                  class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-petrol-50 to-petrol-100 text-petrol-700 ring-1 ring-inset ring-petrol-100"
                  set:html={factorIcons[factor.icon]}
                />
                <h3 class="mt-4 font-display text-lg text-petrol-900">{factor.title[lang]}</h3>
                <p class="mt-2 text-sm text-ink-soft">{factor.text[lang]}</p>
              </div>
            ))
          }
        </div>
        <div class="mt-6 max-w-3xl">
          <Callout variant="info" title={hub.standardNote.title[lang]}>
            {hub.standardNote.text[lang]}
          </Callout>
        </div>
      </section>

      {/* Card navigation: world regions */}
      <section aria-labelledby="regionen-heading">
        <div class="max-w-3xl">
          <h2 id="regionen-heading" class="font-display text-2xl text-petrol-900 sm:text-3xl">{hub.regions.heading[lang]}</h2>
          <p class="mt-3 text-ink-soft">{hub.regions.lead[lang]}</p>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            regionList.map((region) => (
              <RegionCard
                region={region}
                lang={lang}
                href={getLocalizedPath(`/reiseziele/${region.slug}`, lang)}
                labels={cardLabels}
              />
            ))
          }
        </div>
      </section>

      {/* Classification: required vs. recommended */}
      <section aria-labelledby="einordnung-heading">
        <div class="max-w-3xl">
          <h2 id="einordnung-heading" class="font-display text-2xl text-petrol-900 sm:text-3xl">{hub.classification.heading[lang]}</h2>
          <p class="mt-3 text-ink-soft">{hub.classification.lead[lang]}</p>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="card">
            <span class="inline-flex items-center gap-2 rounded-full bg-gold-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gold-700 ring-1 ring-inset ring-gold-300">
              {hub.classification.required.title[lang]}
            </span>
            <p class="mt-4 text-ink-soft">{hub.classification.required.text[lang]}</p>
          </div>
          <div class="card">
            <span class="inline-flex items-center gap-2 rounded-full bg-petrol-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-petrol-700 ring-1 ring-inset ring-petrol-200">
              {hub.classification.recommended.title[lang]}
            </span>
            <p class="mt-4 text-ink-soft">{hub.classification.recommended.text[lang]}</p>
          </div>
        </div>
      </section>

      {/* Sources & medical disclaimer */}
      <div class="max-w-3xl">
        <SourceList sources={sources} lastReviewed={hub.lastReviewed} />
        <aside class="mt-10 rounded-2xl border border-line bg-white/60 p-5 text-sm leading-relaxed text-ink-soft">
          <p class="font-semibold text-petrol-900">{t('footer.disclaimerTitle')}</p>
          <p class="mt-1">{t('footer.disclaimer')}</p>
        </aside>
      </div>
    </div>
  </article>

  <CTA />
</BaseLayout>
