---
/**
 * 404-Seite (Standardsprache Deutsch). Astro liefert diese Datei für nicht
 * gefundene Pfade aus. Bewusst schlicht, mit klarem Rückweg zur Startseite.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('notFound.title')} description={t('notFound.lead')} noindex={true}>
  <section class="u-container flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-display text-7xl font-semibold text-gold-400 sm:text-8xl">404</p>
    <h1 class="mt-4 text-3xl sm:text-4xl">{t('notFound.title')}</h1>
    <p class="mt-4 max-w-md text-ink-soft">{t('notFound.lead')}</p>
    <a href={getLocalizedPath('/', lang)} class="btn-primary mt-8">{t('notFound.back')}</a>
  </section>
</BaseLayout>
