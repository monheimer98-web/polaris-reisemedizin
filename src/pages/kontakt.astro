---
/**
 * Kontakt & Anfahrt (Deutsch). Dünne Seite: KontaktContent rendert den Inhalt
 * inkl. 2-Klick-Karte (Sprache aus der URL). Bewusst OHNE abschließende CTA –
 * die Seite ist selbst Kontakt-Endpunkt. Identisch zur EN-Variante.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import KontaktContent from '../components/KontaktContent.astro';
import { getLangFromUrl } from '../i18n/utils';
import { kontaktPage } from '../data/kontakt';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={kontaktPage.meta.title[lang]} description={kontaktPage.meta.description[lang]}>
  <KontaktContent />
</BaseLayout>
