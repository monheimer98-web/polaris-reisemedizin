---
/**
 * Impressum (Deutsch). Dünne Seite: ImpressumContent rendert die Pflichtangaben
 * nach § 5 DDG (Daten aus site.ts, Sprache aus der URL). Bewusst OHNE CTA –
 * eine Rechtsseite. Identisch zur EN-Variante.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import ImpressumContent from '../components/ImpressumContent.astro';
import { getLangFromUrl } from '../i18n/utils';
import { impressumPage } from '../data/impressum';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={impressumPage.meta.title[lang]} description={impressumPage.meta.description[lang]}>
  <ImpressumContent />
</BaseLayout>
